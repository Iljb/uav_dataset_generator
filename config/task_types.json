{
  "schema_version": "0.1.0",
  "scope": {
    "input_origin": "cluster_task_preallocated_to_single_uav",
    "description": "This project handles single-UAV semantic task parameters after upstream cluster task allocation."
  },
  "global_constraints": {
    "max_payloads_per_uav": 1,
    "payload_field": "payload",
    "stage_rule": "each stage is a compact control phase; each stage must contain exactly one ROBOT_CTRL start action and may contain zero or more SVR actions",
    "final_output_format": "staged_component_actions",
    "output_contains_component_params": false,
    "component_parameter_filling": "downstream_rule_based_step",
    "output_contains_explicit_predecessor": true,
    "component_uuid_policy": "downstream_compiler_assigns_uuid",
    "topology_prev_source_types": ["ROBOT_CTRL"],
    "topology_prev_events": ["success", "failed"],
    "svr_control_outputs": false,
    "svr_can_drive_control_flow": false,
    "svr_start_once_per_task": true,
    "svr_stop_generated": false
  },
  "semantic_input_contract": {
    "required_fields": [
      "uav_id",
      "task_type",
      "role",
      "assigned_area",
      "route_mode",
      "payload",
      "flight",
      "capabilities",
      "safety"
    ],
    "field_groups": {
      "identity": ["uav_id", "task_type", "role"],
      "assignment": ["assigned_area", "route_mode"],
      "platform": ["payload"],
      "flight": ["height_level", "speed_level", "hover_required", "return_home"],
      "capabilities": ["object_detection", "target_tracking", "obstacle_avoidance", "radar_scan", "thermal_scan", "image_capture"],
      "safety": ["preflight_check", "battery_monitor", "battery_risk_level", "gps_required"]
    },
    "capability_schema": {
      "object_detection": {
        "enabled": "boolean",
        "target_classes": "array<string>",
        "notes": "Target classes such as person, vehicle, tower, insulator, or fire must be explicit when enabled."
      },
      "target_tracking": {
        "enabled": "boolean",
        "target_class": "string|null",
        "notes": "Tracking requires an explicit target class and normally depends on object_detection."
      },
      "obstacle_avoidance": {
        "enabled": "boolean",
        "obstacle_level": "low|medium|high|null",
        "notes": "Obstacle avoidance maps to radar scan plus obstacle_avoid_flight only when explicitly enabled."
      },
      "radar_scan": {
        "enabled": "boolean",
        "scan_mode": "single|continuous|null",
        "notes": "Radar scan starts sensor_radar_scan as an SVR sensing service and does not change the main flight mode."
      },
      "thermal_scan": {
        "enabled": "boolean",
        "notes": "Thermal scanning requires an infrared payload."
      },
      "image_capture": {
        "enabled": "boolean",
        "capture_mode": "photo|video|continuous_photo|null",
        "notes": "Image capture requires a camera-capable payload."
      }
    }
  },
  "task_types": [
    {
      "id": "single_uav_area_search",
      "name": "single UAV area search",
      "roles": ["search_unit", "observer"],
      "route_modes": [
        "waypoint",
        "grid",
        "lawnmower",
        "perimeter_patrol",
        "spiral_search",
        "expanding_square"
      ],
      "typical_capabilities": ["image_capture", "object_detection", "target_tracking", "thermal_scan", "radar_scan", "obstacle_avoidance"]
    },
    {
      "id": "single_uav_route_inspection",
      "name": "single UAV route inspection",
      "roles": ["inspection_unit"],
      "route_modes": ["waypoint", "line_follow", "corridor_patrol"],
      "typical_capabilities": ["image_capture", "object_detection", "thermal_scan", "radar_scan", "obstacle_avoidance"]
    },
    {
      "id": "single_uav_fixed_point_observation",
      "name": "single UAV fixed-point observation",
      "roles": ["observer"],
      "route_modes": ["goto_point", "hover", "orbit"],
      "typical_capabilities": ["image_capture", "object_detection", "target_tracking", "thermal_scan", "radar_scan"]
    }
  ]
}
