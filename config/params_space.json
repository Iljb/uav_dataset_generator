{
  "schema_version": "0.3.0",
  "description": "Semantic sampling space for template-only generation. The dataset output contains staged component actions only, not executable component parameters.",
  "constraints": {
    "max_payloads_per_uav": 1,
    "payload_selection": "single_value",
    "all_task_types_allow_all_payloads": true,
    "route_mode_must_match_task_type": true,
    "route_mode_must_match_assigned_target_type": true,
    "output_contains_component_params": false,
    "component_parameter_filling": "downstream_rule_based_step",
    "svr_control_outputs": false,
    "svr_can_drive_control_flow": false,
    "svr_start_once_per_task": true,
    "svr_stop_generated": false,
    "topology_prev_source_types": ["ROBOT_CTRL"],
    "topology_prev_events": ["success", "failed"],
    "exactly_one_robot_ctrl_start_per_stage_when_failure_strategy_disabled": true,
    "guarded_robot_ctrl_stage_allowed_when_failure_strategy_enabled": true,
    "failure_strategy_default_enabled": true,
    "object_detection_requires_target_classes": true,
    "target_tracking_requires_target_class": true,
    "target_tracking_requires_object_detection": true
  },
  "semantic_params": {
    "uav_id": ["uav_01", "uav_02", "uav_03", "uav_04", "uav_05", "uav_06"],
    "task_type": [
      "single_uav_area_search",
      "single_uav_route_inspection",
      "single_uav_fixed_point_observation"
    ],
    "role": ["search_unit", "inspection_unit", "observer"],
    "assigned_area": [
      "grid_A1",
      "grid_A2",
      "grid_A3",
      "route_segment_B1",
      "route_segment_B2",
      "route_segment_B3",
      "point_C1",
      "point_C2",
      "point_C3"
    ],
    "route_mode": ["waypoint", "grid", "lawnmower", "line_follow", "goto_point", "hover"],
    "payload": ["visible_camera", "infrared_camera", "radar"],
    "complexity": ["simple", "medium", "complex"]
  },
  "task_profiles": {
    "single_uav_area_search": {
      "target_types": ["area"],
      "roles": ["search_unit", "observer"],
      "route_modes": ["waypoint", "grid", "lawnmower"],
      "payloads": ["visible_camera", "infrared_camera", "radar"]
    },
    "single_uav_route_inspection": {
      "target_types": ["line"],
      "roles": ["inspection_unit"],
      "route_modes": ["waypoint", "line_follow"],
      "payloads": ["visible_camera", "infrared_camera", "radar"]
    },
    "single_uav_fixed_point_observation": {
      "target_types": ["point"],
      "roles": ["observer"],
      "route_modes": ["goto_point", "hover"],
      "payloads": ["visible_camera", "infrared_camera", "radar"]
    }
  },
  "assigned_targets": {
    "grid_A1": {
      "type": "area",
      "description": "Northwest search grid"
    },
    "grid_A2": {
      "type": "area",
      "description": "East search grid"
    },
    "grid_A3": {
      "type": "area",
      "description": "Large open search grid"
    },
    "route_segment_B1": {
      "type": "line",
      "description": "Short inspection route"
    },
    "route_segment_B2": {
      "type": "line",
      "description": "Curved inspection route"
    },
    "route_segment_B3": {
      "type": "line",
      "description": "Long inspection route"
    },
    "point_C1": {
      "type": "point",
      "description": "Observation point near target C1"
    },
    "point_C2": {
      "type": "point",
      "description": "Observation point near target C2"
    },
    "point_C3": {
      "type": "point",
      "description": "Observation point near target C3"
    }
  },
  "route_to_robot_ctrl": {
    "goto_point": {
      "target_types": ["point"],
      "sequence": ["goto_point"]
    },
    "hover": {
      "target_types": ["point"],
      "sequence": ["goto_point", "hover"]
    },
    "line_follow": {
      "target_types": ["line"],
      "sequence": ["waypoint_flight"]
    },
    "waypoint": {
      "target_types": ["line", "area"],
      "sequence": ["waypoint_flight"]
    },
    "grid": {
      "target_types": ["area"],
      "sequence": ["waypoint_flight"]
    },
    "lawnmower": {
      "target_types": ["area"],
      "sequence": ["waypoint_flight"]
    }
  },
  "route_to_roles": {
    "goto_point": {
      "target_types": ["point"],
      "sequence": ["navigation.point"]
    },
    "hover": {
      "target_types": ["point"],
      "sequence": ["navigation.point", "observation.hover"]
    },
    "line_follow": {
      "target_types": ["line"],
      "sequence": ["navigation.line"]
    },
    "waypoint": {
      "target_types": ["line", "area"],
      "sequence": ["navigation.path"]
    },
    "grid": {
      "target_types": ["area"],
      "sequence": ["navigation.area"]
    },
    "lawnmower": {
      "target_types": ["area"],
      "sequence": ["navigation.area"]
    }
  },
  "flight": {
    "height_level": ["low", "medium", "high"],
    "speed_level": ["slow", "normal", "fast"],
    "hover_required": [true, false],
    "return_home": [true]
  },
  "payloads": {
    "visible_camera": {
      "display_name": "visible camera",
      "supports": ["image_capture", "object_detection", "target_tracking"],
      "candidate_svr_components": [
        "sensor_camera_scan",
        "object_detect",
        "gimbal_control"
      ],
      "candidate_robot_ctrl_components": ["target_tracking"]
    },
    "infrared_camera": {
      "display_name": "infrared camera",
      "supports": ["thermal_scan"],
      "candidate_svr_components": ["sensor_ir_scan", "gimbal_control"]
    },
    "radar": {
      "display_name": "radar",
      "supports": ["obstacle_avoidance"],
      "candidate_svr_components": ["sensor_radar_scan"],
      "candidate_robot_ctrl_components": ["obstacle_avoid_flight"]
    }
  },
  "capabilities": {
    "image_capture": {
      "enabled": [true, false],
      "capture_mode": ["photo", "video", "continuous_photo"]
    },
    "thermal_scan": {
      "enabled": [true, false],
      "scan_mode": ["single", "continuous"],
      "target_temperature_hint": ["none", "human_body", "overheated_equipment", "fire_source"]
    },
    "object_detection": {
      "enabled": [true, false],
      "target_classes": [
        "person",
        "vehicle",
        "tower",
        "insulator",
        "fire",
        "building",
        "animal"
      ],
      "confidence_level": ["low", "medium", "high"]
    },
    "target_tracking": {
      "enabled": [true, false],
      "target_class": ["person", "vehicle", "animal"],
      "tracking_priority": ["low", "medium", "high"]
    },
    "obstacle_avoidance": {
      "enabled": [true, false],
      "obstacle_level": ["low", "medium", "high"]
    }
  },
  "capability_to_svr": {
    "image_capture": ["sensor_camera_scan"],
    "thermal_scan": ["sensor_ir_scan"],
    "object_detection": ["sensor_camera_scan", "object_detect"],
    "target_tracking": ["sensor_camera_scan", "object_detect"],
    "obstacle_avoidance": ["sensor_radar_scan"]
  },
  "capability_to_robot_ctrl": {
    "target_tracking": ["target_tracking"],
    "obstacle_avoidance": ["obstacle_avoid_flight"]
  },
  "object_classes": ["person", "vehicle", "tower", "insulator", "fire", "building", "animal"],
  "safety": {
    "preflight_check": [true],
    "battery_monitor": [true],
    "battery_risk_level": ["low", "medium", "high"],
    "gps_required": [true]
  },
  "safety_to_component": {
    "preflight_check": ["preflight_check"],
    "battery_monitor": ["battery_level", "battery_warning"]
  },
  "mission_tail": {
    "return_home": ["return_home"],
    "land": ["land"]
  },
  "failure_strategy_rules": {
    "enabled": true,
    "default_policy": "none",
    "max_branches_per_task": 3,
    "policy_selection": "balanced_by_trigger_role",
    "branch_count_by_complexity": {
      "simple": [0, 1],
      "medium": [1, 2],
      "complex": [2, 3]
    },
    "policies": {
      "safe_return": {
        "trigger_roles": ["navigation.path", "navigation.line", "navigation.area", "navigation.point", "navigation.obstacle_avoid"],
        "on_failed": ["flight.return", "flight.land"],
        "selection_weight": 1.0
      },
      "safe_land": {
        "trigger_roles": ["flight.takeoff", "flight.altitude_up"],
        "on_failed": ["flight.land"],
        "selection_weight": 0.5
      },
      "hold_then_return": {
        "trigger_roles": ["tracking.target", "observation.hover"],
        "on_failed": ["observation.hover", "flight.return", "flight.land"],
        "selection_weight": 0.5
      }
    }
  },
  "compatibility_rules": [
    {
      "if": {"task_type": "*"},
      "allowed_payloads": ["visible_camera", "infrared_camera", "radar"]
    },
    {
      "if": {"payload": "visible_camera"},
      "allowed_capabilities": ["image_capture", "object_detection", "target_tracking"]
    },
    {
      "if": {"payload": "infrared_camera"},
      "allowed_capabilities": ["thermal_scan"]
    },
    {
      "if": {"payload": "radar"},
      "allowed_capabilities": ["obstacle_avoidance"]
    },
    {
      "if": {"capability": "target_tracking", "enabled": true},
      "requires": [{"capability": "object_detection", "enabled": true}]
    },
    {
      "if": {"capability": "target_tracking", "enabled": true},
      "allowed_payloads": ["visible_camera"]
    },
    {
      "if": {"capability": "object_detection", "enabled": true},
      "allowed_payloads": ["visible_camera"]
    },
    {
      "if": {"capability": "thermal_scan", "enabled": true},
      "allowed_payloads": ["infrared_camera"]
    },
    {
      "if": {"capability": "obstacle_avoidance", "enabled": true},
      "allowed_payloads": ["radar"]
    }
  ],
  "sampling": {
    "default_random_seed": 42,
    "max_samples_per_task_profile": 200,
    "complexity_to_component_action_count": {
      "simple": {"min": 4, "max": 7},
      "medium": {"min": 7, "max": 11},
      "complex": {"min": 11, "max": 16}
    }
  }
}
