{
  "schema_version": "0.1.0",
  "constraints": {
    "max_payloads_per_uav": 1,
    "payload_selection": "single_value",
    "object_detection_requires_target_classes": true,
    "target_tracking_requires_target_class": true
  },
  "payloads": {
    "visible_camera": {
      "display_name": "visible camera",
      "supports": ["image_capture", "object_detection", "target_tracking"],
      "candidate_svr_components": ["sensor_camera_init", "sensor_camera_scan", "object_detect", "target_tracking", "gimbal_control"]
    },
    "infrared_camera": {
      "display_name": "infrared camera",
      "supports": ["thermal_scan"],
      "candidate_svr_components": ["sensor_ir_scan", "gimbal_control"]
    },
    "radar": {
      "display_name": "radar",
      "supports": ["obstacle_avoidance"],
      "candidate_svr_components": ["sensor_radar_scan"],
      "candidate_robot_ctrl_components": ["obstacle_avoid_flight"]
    }
  },
  "semantic_params": {
    "uav_id": ["uav_01", "uav_02", "uav_03", "uav_04"],
    "task_type": [
      "single_uav_area_search",
      "single_uav_route_inspection",
      "single_uav_fixed_point_observation"
    ],
    "role": ["search_unit", "inspection_unit", "observer"],
    "assigned_area": ["grid_A1", "grid_A2", "route_segment_B1", "point_C1"],
    "route_mode": ["waypoint", "grid", "lawnmower", "line_follow", "goto_point", "hover"],
    "payload": ["visible_camera", "infrared_camera", "radar"]
  },
  "flight": {
    "height_m": [40, 60, 80, 100, 120],
    "speed_mps": [3, 5, 8],
    "hover_sec": [0, 5, 10, 20, 30],
    "return_home": [true]
  },
  "capabilities": {
    "image_capture": {
      "enabled": [true, false],
      "capture_mode": ["photo", "video", "continuous_photo"]
    },
    "thermal_scan": {
      "enabled": [true, false],
      "scan_mode": ["single", "continuous"],
      "target_temperature_hint": ["none", "human_body", "overheated_equipment", "fire_source"]
    },
    "object_detection": {
      "enabled": [true, false],
      "target_classes": [
        "person",
        "vehicle",
        "tower",
        "insulator",
        "fire",
        "building",
        "animal"
      ],
      "confidence_threshold": [0.4, 0.5, 0.6]
    },
    "target_tracking": {
      "enabled": [true, false],
      "target_class": ["person", "vehicle", "animal"],
      "min_confidence": [0.4, 0.5, 0.6]
    },
    "obstacle_avoidance": {
      "enabled": [true, false],
      "obstacle_level": ["low", "medium", "high"],
      "obstacle_distance_threshold_m": [3, 5, 8]
    }
  },
  "safety": {
    "preflight_check": [true],
    "battery_monitor": [true],
    "min_battery_percent": [20, 30, 40]
  },
  "component_params": {
    "takeoff": {
      "height": [40, 60, 80, 100],
      "timeout_sec": [30, 60],
      "height_tolerance": [0.3, 0.5, 1.0]
    },
    "waypoint_flight": {
      "hold_sec": [1, 3, 5],
      "action_hold_sec": [1, 3, 5],
      "position_tolerance": [0.5, 1.0, 2.0],
      "yaw_tolerance_deg": [3, 5, 10]
    },
    "goto_point": {
      "position_tolerance": [0.5, 1.0, 2.0],
      "yaw_tolerance_deg": [3, 5, 10],
      "timeout_sec": [60, 120]
    },
    "hover": {
      "duration_sec": [5, 10, 20, 30],
      "position_tolerance": [0.5, 1.0]
    },
    "sensor_camera_scan": {
      "capture_mode": ["photo", "video", "continuous_photo"],
      "continuous_photo_count": [3, 5, 10],
      "video_duration_sec": [10, 20, 30]
    },
    "sensor_ir_scan": {
      "scan_mode": ["single", "continuous"],
      "frame_rate_hz": [5, 10, 15],
      "emissivity": [0.85, 0.9, 0.95]
    },
    "object_detect": {
      "camera_topic": ["/visible_camera/capture_image", "/visible_camera/video_frame"],
      "target_classes": ["person", "vehicle", "tower", "insulator", "fire", "building", "animal"],
      "confidence_threshold": [0.4, 0.5, 0.6],
      "nms_threshold": [0.4, 0.5]
    },
    "target_tracking": {
      "target_class_id": ["person", "vehicle", "animal"],
      "min_confidence": [0.4, 0.5, 0.6],
      "max_lost_time_sec": [1, 3, 5]
    },
    "obstacle_avoid_flight": {
      "obstacle_distance_threshold_m": [3, 5, 8],
      "front_fov_deg": [60, 90, 120],
      "side_fov_deg": [45, 60],
      "avoid_lateral_step_m": [1, 2],
      "avoid_forward_step_m": [1, 2],
      "avoid_vertical_step_m": [1, 2]
    }
  },
  "compatibility_rules": [
    {
      "if": {"payload": "visible_camera"},
      "allowed_capabilities": ["image_capture", "object_detection", "target_tracking"]
    },
    {
      "if": {"payload": "infrared_camera"},
      "allowed_capabilities": ["thermal_scan"]
    },
    {
      "if": {"payload": "radar"},
      "allowed_capabilities": ["obstacle_avoidance"]
    },
    {
      "if": {"capability": "target_tracking", "enabled": true},
      "requires": [{"capability": "object_detection", "enabled": true}]
    }
  ]
}
