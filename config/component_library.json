  "scheduling_rules": {
    "stage_model": {
      "robot_ctrl_per_stage": 1,
      "svr_per_stage": "zero_or_more",
      "description": "Each execution stage must contain exactly one ROBOT_CTRL component. SVR components may run in parallel with that ROBOT_CTRL stage."
    },
    "component_types": {
      "ROBOT_CTRL": {
        "description": "Flight-control component that sends movement commands to the flight controller.",
        "parallel_limit": 1,
        "required_per_active_stage": true
      },
      "SVR": {
        "description": "Data, perception, trigger, or communication component. It does not directly control aircraft motion.",
        "parallel_limit": null,
        "required_per_active_stage": false
      }
    }
  },
