  "scheduling_rules": {
    "stage_model": {
      "stage_definition": "Compact control phase for topology-only model output",
      "robot_ctrl_start_per_stage": "exactly_one",
      "svr_per_stage": "zero_or_more",
      "description": "Each stage groups exactly one ROBOT_CTRL start action plus zero or more SVR service starts. A required SVR is inserted at or before the first ROBOT_CTRL that consumes its topic and is not inserted again."
    },
    "control_flow": {
      "prev_source_component_types": ["ROBOT_CTRL"],
      "prev_events": ["success", "failed"],
      "svr_can_drive_control_flow": false,
      "svr_control_outputs": [],
      "svr_start_once_per_task": true,
      "svr_stop_generated": false,
      "data_channels_are_not_control_edges": true
    },
    "component_types": {
      "ROBOT_CTRL": {
        "description": "Flight-control component. It may emit success or failed control outputs and can trigger later component actions.",
        "parallel_limit": 1,
        "required_per_active_flight_phase": true,
        "can_drive_control_flow": true
      },
      "SVR": {
        "description": "Data, perception, or communication component. It has no control outputs, cannot trigger control flow, and should be treated as a reusable service node.",
        "parallel_limit": null,
        "required_per_active_flight_phase": false,
        "can_drive_control_flow": false,
        "lifecycle": "starts once when first needed and keeps publishing through ROS topics; generated topology does not emit SVR stop actions"
      }
    }
  },
